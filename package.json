{
  "name": "applyproof",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/extension",
    "apps/web-demo",
    "packages/sample-data",
    "packages/shared-types"
  ],
  "scripts": {
    "dev:extension": "npm run dev --workspace @applyproof/extension",
    "dev:web": "npm run dev --workspace @applyproof/web-demo",
    "dev:api": ".venv/bin/python -m uvicorn app.main:app --reload --app-dir apps/api",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && .venv/bin/python -m ruff check apps/api",
    "typecheck": "npm run typecheck --workspaces --if-present && .venv/bin/python -m mypy apps/api/app",
    "test": "npm run test --workspaces --if-present && .venv/bin/python -m pytest apps/api/tests"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.15",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
